// Salva o struct montado em um arquivo binário
void salvarJogo(JogoSave s) {
    ofstream f(ARQUIVO_SAVE, ios::binary);
    if(f) { f.write((char*)&s, sizeof(JogoSave)); f.close(); }
}

// Sobrecarga da função acima que monta o struct pegando as variáveis globais atuais
void salvarJogo(string player = "Player1") {
    JogoSave s; 
    strncpy(s.jogador, player.c_str(), 31); s.jogador[31] = 0;
    obterDataAtual(s.data, 32); 
    s.fase = faseAtual; s.pontuacao = pontuacao;
    s.bombasUsadas = bombasUsadas; s.movimentos = movimentos;
    s.tempoSegundos = (long)(time(0) - tempoInicio); 
    s.vidas = vidas; s.dificuldade = dificuldade;
    salvarJogo(s);
}

// Lê o arquivo binário e tenta preencher a struct JogoSave passada por referência
bool lerSave(JogoSave &s) {
    ifstream f(ARQUIVO_SAVE, ios::binary);
    if(!f) return false;
    f.read((char*)&s, sizeof(JogoSave)); 
    bool ok = (f.gcount() == sizeof(JogoSave)); // Verifica se a leitura foi completa
    f.close(); return ok;
}

// Carrega as variáveis globais a partir do arquivo salvo e retoma o tempo corrido
bool aplicarSave() {
    JogoSave s; 
    if(!lerSave(s)) return false;
    faseAtual = s.fase; pontuacao = s.pontuacao; bombasUsadas = s.bombasUsadas;
    movimentos = s.movimentos; vidas = s.vidas; dificuldade = s.dificuldade;
    nomeJogador = s.jogador; tempoInicio = time(0) - s.tempoSegundos; 
    return true;
}

// RECURSIVIDADE: Insere uma nova pontuação no Rank ordenando-a de forma decrescente
void inserirRankRecursivo(RankEntry* arr, int &qtd, RankEntry novo, int i = 0) {
    // Caso base: Chegamos no final do array válido, se tiver espaço, apenas insere
    if(i >= qtd) { 
        if(qtd < 10) arr[qtd++] = novo; 
        return; 
    }
    // Se a pontuação nova for maior que a posição atual, troca elas e "empurra" a antiga pra baixo
    if(novo.pontuacao > arr[i].pontuacao) {
        RankEntry temp = arr[i]; 
        arr[i] = novo;
        if(qtd < 10) inserirRankRecursivo(arr, qtd, temp, i+1);
        return;
    }
    // Caso a pontuação nova seja menor, apenas tenta a próxima posição (i+1)
    inserirRankRecursivo(arr, qtd, novo, i+1);
}

// Pega os dados atuais, adiciona no rank e re-salva o arquivo binário
void registrarNoRank(string player, int pts, int fase) {
    RankEntry arr[10]; 
    int qtd = 0; 
    ifstream fin(ARQUIVO_RANK, ios::binary);
    if(fin) {
        while(qtd < 10) {
            RankEntry r; fin.read((char*)&r, sizeof(RankEntry));
            if(fin.gcount() != sizeof(RankEntry)) break; 
            arr[qtd++] = r;
        }
        fin.close();
    }
    RankEntry novo; 
    strncpy(novo.jogador, player.c_str(), 31); novo.jogador[31] = 0;
    obterDataAtual(novo.data, 32); novo.pontuacao = pts; novo.fase = fase;
    
    // Chama a função recursiva de ordenação
    inserirRankRecursivo(arr, qtd, novo);
    
    ofstream fout(ARQUIVO_RANK, ios::binary | ios::trunc);
    if(fout) { 
        for(int i=0; i<qtd; i++) fout.write((char*)&arr[i], sizeof(RankEntry)); 
        fout.close(); 
    }
}

// Carrega o Top 10 para o array
int lerRank(RankEntry* arr, int max) {
    int qtd = 0; ifstream fin(ARQUIVO_RANK, ios::binary);
    if(!fin) return 0;
    while(qtd < max) {
        RankEntry r; fin.read((char*)&r, sizeof(RankEntry));
        if(fin.gcount() != sizeof(RankEntry)) break; 
        arr[qtd++] = r;
    }
    fin.close(); return qtd;
}


