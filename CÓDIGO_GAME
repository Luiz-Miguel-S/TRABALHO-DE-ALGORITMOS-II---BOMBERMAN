// Captura a data e hora do sistema e formata em uma string
void obterDataAtual(char* buffer, int tam) {
    time_t t = time(0); 
    struct tm* lt = localtime(&t);
    sprintf(buffer, "%02d/%02d/%04d %02d:%02d",
        lt->tm_mday, lt->tm_mon+1, lt->tm_year+1900, lt->tm_hour, lt->tm_min);
}


