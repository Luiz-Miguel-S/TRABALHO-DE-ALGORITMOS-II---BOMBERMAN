}

// Zera apenas as condições críticas da fase em andamento se o jogador perder uma vida (Soft Reset)
void resetarEstadoPartida() {
    bombaAtiva = false; bombaExplodiu = false;
    gameOverColideInimigo = false; gameOverExplosao = false; gameWin = false;
    fimTimer = 1; vidas = 3;
}

// Zera TODA a partida quando da Game Over ou quando inicia novo jogo (Hard Reset)
void resetarPartidaCompleta() {
    resetarEstadoPartida();
    pontuacao = 0; bombasUsadas = 0; movimentos = 0; caixasDestruidas = 0; faseAtual = 1;
}

// *** CÉREBRO DO JOGO (ENGINE E LOOPS DE RENDERIZAÇÃO) ***
int executarFase() {
    int delayInimigo = 0, delayBot = 0;
    HANDLE out = GetStdHandle(STD_OUTPUT_HANDLE); COORD coord = {0, 0};

    int x=7, y=11; // Local de nascimento padrão do Player (Centro esquerda)
    int m[15][25];
    
    inicializarMapa(m, faseAtual);
    gerarBlocosAleatorios(m, x, y);
    resetarInimigos(faseAtual, dificuldade, m);

    bombaAtiva = false; bombaExplodiu = false;
    gameOverColideInimigo = false; gameOverExplosao = false;
    fimTimer = 1; portalAtivo = false; portalX = -1; portalY = -1;

    if(tempoInicio == 0) tempoInicio = time(0);
    char tecla;
    system("cls"); // Limpa tela antes de começar os frames


    // FRAME LOOP
    while(true) {
        SetConsoleCursorPosition(out, coord); // Volta para a linha zero (Pintar tela sem piscar 'flicker')

        // Renderização (DESENHO DO MAPA)
        for(int i=0; i<15; i++) {
            for(int j=0; j<25; j++) {
                // Sobreposição de Entidades (Para os bonecos andarem em cima do fogo/portal sem apagar ele da memória da matriz)
                if(i==x && j==y) { cout<<"🧑"; continue; }
                
                bool desenhouEntidade = false;
                for(int k=0; k<numInimigosAtivos; k++) {
                    if(inimigos[k].vivo && i==inimigos[k].x && j==inimigos[k].y) {
                        cout<<"👻"; desenhouEntidade = true; break;
                    }
                }
                if(desenhouEntidade) continue;

                if(bossAtivo && boss.vivo && i==boss.x && j==boss.y) {
                    cout<<"🧌"; continue;
                }

                // Desenho do ambiente principal
                switch (m[i][j]) {
                    case 0: cout<<"  "; break;  // Espaço Duplo para compensar larguras dos emojis
                    case 1: cout<<"🧱"; break;
                    case 4: cout<<"🕸️"; break;
                    case 5: cout<<"💣"; break;
                    case 6: cout<<"🔥"; break;
                    case 7: cout<<"🌀"; break;
                }
            }
            cout<<"\n";
        }
        
        desenharHUD();

        // -------------------------------------------------------------
        // CÁLCULOS DE COLISÃO
        // -------------------------------------------------------------
        if (m[x][y] == 6) gameOverExplosao = true; // Você pisou na explosão?
        
        for(int k=0; k<numInimigosAtivos; k++) {
            if(!inimigos[k].vivo) continue;
            // Você bateu no inimigo?
            if(x == inimigos[k].x && y == inimigos[k].y) gameOverColideInimigo = true;
            
            // Inimigo pisou em bomba ou explosão? (Ele morre)
            if(m[inimigos[k].x][inimigos[k].y] == 6 || m[inimigos[k].x][inimigos[k].y] == 5) {
                inimigos[k].vivo = false; pontuacao += 100; inimigosVivos--;
            }
        }
        if(bossAtivo && boss.vivo) {
            if(x == boss.x && y == boss.y) gameOverColideInimigo = true;
            if(m[boss.x][boss.y] == 6 || m[boss.x][boss.y] == 5) {
                boss.vivo = false; pontuacao += 500; inimigosVivos--;
            }
        }

        // Verifica condição de surgimento do Portal
        if(inimigosVivos <= 0 && !portalAtivo) {
            colocarPortal(m);
            SetConsoleCursorPosition(out, coord); cout << "\n";
            setCor(46); imprimirCentralizado(">>> PORTAL ABERTO! <<<", 70); setCor(7);
            Sleep(1500); system("cls");
        }
        // Vitória da Fase
        if(portalAtivo && x == portalX && y == portalY) {
            pontuacao += calcularBonusFinal();
            return (faseAtual >= 3) ? ESTADO_VITORIA : ESTADO_PROXIMA_FASE;
        }

        // Sistema de Vidas e Mortes
        if(gameOverColideInimigo || gameOverExplosao) {
            vidas--;
            if(vidas > 0) {
                x = 7; y = 11; // Renasce no local seguro padrão
                if(m[x][y] == 6) m[x][y] = 0; // Apaga o fogo se ele nasceu em cima de um
                gameOverColideInimigo = false; gameOverExplosao = false;
                
                SetConsoleCursorPosition(out, coord); cout << "\n";
                setCor(196); imprimirCentralizado(">>> VOCE PERDEU UMA VIDA! <<<", 70); setCor(7);
                Sleep(800); system("cls");
            } else {
                return ESTADO_DERROTA; // Acabaram as vidas
            }
        }

        // -------------------------------------------------------------
        // RESOLUÇÃO DA LÓGICA DE BOMBAS
        // -------------------------------------------------------------
        if(bombaAtiva) {
            bombaTimer--;
            if(bombaTimer <= 0) { // Estourou!
                m[bombaX][bombaY] = 0;
                
                // Quebra caixas nas adjacências e pontua
                if(m[bombaX-1][bombaY]==4) { caixasDestruidas++; pontuacao += 25; }
                if(m[bombaX+1][bombaY]==4) { caixasDestruidas++; pontuacao += 25; }
                if(m[bombaX][bombaY-1]==4) { caixasDestruidas++; pontuacao += 25; }
                if(m[bombaX][bombaY+1]==4) { caixasDestruidas++; pontuacao += 25; }
                
                explosao(bombaX, bombaY, m); 
                bombaAtiva = false; fimTimer = 8; bombaExplodiu = true;
            }
        }
        
        // Timer pra manter as chamas da explosão visíveis antes de limpar a matriz de volta pra Vazio(0)
        if(bombaExplodiu) {
            fimTimer--; 
            if(fimTimer <= 0) { fimExplosao(bombaX, bombaY, m); bombaExplodiu = false; }
        }

        // -------------------------------------------------------------
        // DETECÇÃO DE BOTÕES OU AÇÃO DA IA
        // -------------------------------------------------------------
        if(modoAutoPlay) {
            delayBot++; // O bot pensa a cada X frames para não "teletransportar" rápido demais na tela
            if(delayBot >= 3) { 
                bool tentarBomba = false; 
                jogarBot(x, y, m, tentarBomba); 
                movimentos++;
                if(tentarBomba && !bombaAtiva && !bombaExplodiu) { bomba(x, y, m); bombasUsadas++; }
                delayBot = 0;
            }
            // Permite intervenção humana pra abortar o autoplay
            if(_kbhit()) { char c = _getch(); if(c == 'f' || c == 'F') return ESTADO_DESISTIU; }
            
        } else {
            // Se o Jogador Apertar uma Tecla
            if(_kbhit()) {
                tecla = _getch();
                switch(tecla) {
                    case 'w': if(m[x-1][y]==0 || m[x-1][y]==6 || m[x-1][y]==7) { x--; movimentos++; } break;
                    case 's': if(m[x+1][y]==0 || m[x+1][y]==6 || m[x+1][y]==7) { x++; movimentos++; } break;
                    case 'a': if(m[x][y-1]==0 || m[x][y-1]==6 || m[x][y-1]==7) { y--; movimentos++; } break;
                    case 'd': if(m[x][y+1]==0 || m[x][y+1]==6 || m[x][y+1]==7) { y++; movimentos++; } break;
                    case 'b': if(!bombaAtiva && !bombaExplodiu) { bomba(x, y, m); bombasUsadas++; } break;
                    case 'p': salvarJogo(nomeJogador); return ESTADO_DESISTIU;
                    case 'f': return ESTADO_DESISTIU;
                }
            }
        }

        // -------------------------------------------------------------
        // ATUALIZAÇÃO DOS INIMIGOS
        // -------------------------------------------------------------
        delayInimigo++;
        if(delayInimigo >= 5) { // Inimigos andam mais devagar que o player (a cada 5 frames)
            int chance = (dificuldade == 2) ? 50 : ((dificuldade == 3) ? 75 : 0);
            for(int k=0; k<numInimigosAtivos; k++) {
                if(inimigos[k].vivo) moverInimigoIA(inimigos[k].x, inimigos[k].y, m, x, y, chance);
            }
            if(bossAtivo && boss.vivo) moverBoss(boss.x, boss.y, m, x, y);
            delayInimigo = 0;
        }
        
        Sleep(60); // Controla a velocidade geral do "Loop do Jogo" (~16FPS)
    }
    return ESTADO_DESISTIU;
}

