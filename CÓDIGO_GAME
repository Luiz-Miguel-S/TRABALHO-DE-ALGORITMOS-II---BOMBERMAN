// Cria a geometria dos mapas de acordo com a faseAtual (Paredes indestrutíveis)
void inicializarMapa(int m[][25], int fase) {
    // Zera tudo primeiro
    for(int i=0; i<15; i++) for(int j=0; j<25; j++) m[i][j] = 0;
    
    // Desenha as bordas fixas externas
    for(int i=0; i<15; i++) { m[i][0]=1; m[i][24]=1; }
    for(int j=0; j<25; j++) { m[0][j]=1; m[14][j]=1; }

    if(fase <= 1) {
        // Fase 1 Clássica (Grid padrão)
        for(int i=2; i<14; i+=2) for(int j=2; j<24; j+=2) m[i][j] = 1;
    } else if(fase == 2) {
        // Fase Aberta
        for(int i=3; i<13; i+=3) for(int j=3; j<23; j+=3) m[i][j] = 1;
        m[6][7]=1; m[7][7]=1; m[7][17]=1; m[8][17]=1;
    } else {
        // Fase 3 (Arena pro Boss)
        for(int i=3; i<5; i++) { for(int j=3; j<5; j++) m[i][j]=1; for(int j=20; j<22; j++) m[i][j]=1; }
        for(int i=10; i<12; i++) { for(int j=3; j<5; j++) m[i][j]=1; for(int j=20; j<22; j++) m[i][j]=1; }
        m[6][14]=1; m[7][14]=1; m[8][14]=1;
    }
}

// Preenche os espaços vazios do mapa com os blocos quebráveis baseados na % densidade
void gerarBlocosAleatorios(int m[][25], int spawnX, int spawnY, int densidade = 55) {
    for(int i=1; i<14; i++) {
        for(int j=1; j<24; j++) {
            if(m[i][j] != 0) continue;
            // Cria uma "área segura" de 2 blocos de distância do jogador pra ele não nascer preso
            if(abs(i - spawnX) + abs(j - spawnY) <= 2) continue; 
            
            if(rand() % 100 < densidade) m[i][j] = 4;
        }
    }
}

// Restaura os dados dos inimigos nos locais fixos para o início de cada fase
void resetarInimigos(int fase, int dif, int m[][25]) {
    numInimigosAtivos = (dif == 1) ? 3 : ((dif == 2) ? 5 : 7); // Define quantos baseado na dificuldade
    
    // Pontos fixos de spawn para espalhar eles no mapa
    int pos[7][2] = {{1,1}, {13,1}, {1,23}, {13,23}, {7,2}, {7,22}, {13,12}};
    for(int i = 0; i < numInimigosAtivos; i++) {
        inimigos[i].x = pos[i][0]; inimigos[i].y = pos[i][1];
        inimigos[i].vivo = true; 
        m[pos[i][0]][pos[i][1]] = 0; // Se gerou caixa no spawn deles, apaga a caixa!
    }
    
    // O Boss só aparece na Fase 3 + Difícil (Level Máximo)
    bossAtivo = (fase == 3 && dif == 3);
    if(bossAtivo) { 
        boss.x = 7; boss.y = 18; boss.vivo = true; m[7][18] = 0; 
    }
    
    inimigosVivos = numInimigosAtivos + (bossAtivo ? 1 : 0);
}

// Sorteia o lugar do mapa (onde esteja livre) para desenhar o portal verde de fim de fase
void colocarPortal(int m[][25], int tentativas = 200) {
    if(tentativas <= 0) { // Safety check: Se der azar 200 vezes seguidas, varre o mapa linearmente e acha o primeiro buraco
        for(int i=1; i<14; i++) for(int j=1; j<24; j++)
            if(m[i][j] == 0) { m[i][j]=7; portalX=i; portalY=j; portalAtivo=true; return; }
        return;
    }
    int i = 1 + rand() % 13; int j = 1 + rand() % 23;
    if(m[i][j] == 0) { m[i][j]=7; portalX=i; portalY=j; portalAtivo=true; return; }
    colocarPortal(m, tentativas - 1);
}

