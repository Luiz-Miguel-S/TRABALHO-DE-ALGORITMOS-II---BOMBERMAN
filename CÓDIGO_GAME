        m[bombaX][bombaY] = 5; //ATRIBUIÇÃO DA BOMBA NO MAPA
        }
    }

void explosao(int x, int y, int m [][25]){

    m[x][y] = 6;// INSERÇÃO DA BOMBA ONDE ELA ESTÁ LOCALIZADA

    //VERIFICAÇÃO DE CONDIÇÃO PARA EXPLOSÃO.

    if (m[x-1][y]==0 or m[x-1][y]==4){

        m[x-1][y]= 6;
    }

    if (m[x+1][y]==0 or m[x+1][y]==4){

        m[x+1][y]= 6;
    }

    if (m[x][y-1]==0 or m[x][y-1]==4){

        m[x][y-1]= 6;
    }

    if (m[x][y+1]==0 or m[x][y+1]==4){

        m[x][y+1]= 6;
    }

}


void fimExplosao(int x, int y, int m [][25]){

    //VERIFICAÇÃO DE ARÉAS QUE ESTÃO COM EXPLOSÃO.

    if (m[x][y] == 6){

        m[x][y] = 0;
    }

    if (m[x-1][y]==6){

        m[x-1][y]= 0;
    }

    if (m[x+1][y]==6){

        m[x+1][y]= 0;
    }

    if (m[x][y-1]==6){

        m[x][y-1]= 0;
    }

    if (m[x][y+1]==6){

        m[x][y+1]= 0;
    }


}

