// =================================================================
// === MAIN (PONTO DE ENTRADA DO PROGRAMA) =========================
// =================================================================
int main() {
    srand(time(0)); // Inicializa a semente randômica para os números aleatórios das fases
    
    // Força o terminal clássico do Windows a interpretar codificação de texto UTF-8 (Para mostrar emojis)
    SetConsoleOutputCP(CP_UTF8); 

    // Oculta o cursor que fica piscando na tela preta (deixa o jogo com mais cara de jogo e menos de DOS)
    HANDLE out = GetStdHandle(STD_OUTPUT_HANDLE);
    CONSOLE_CURSOR_INFO cursorInfo;
    GetConsoleCursorInfo(out, &cursorInfo);
    cursorInfo.bVisible = false;
    SetConsoleCursorInfo(out, &cursorInfo);

    // Sistema Base de Menu e Controle Geral
    while(true) {
        int op = menuPrincipal();
        
        // JOGAR NORMAL ou AUTOPLAY
        if(op == 1 || op == 7) { 
            modoAutoPlay = (op == 7);
            nomeJogador = modoAutoPlay ? "Computador" : "Player1";
            resetarPartidaCompleta(); 
            dificuldade = telaSelecionarDificuldade(); 
            tempoInicio = time(0);
            
            // Loop de encadeamento das Fases (1 ao 3)
            while(true) {
                int estado = executarFase(); // Entrega o controle principal pra Engine gráfica
                
                // Trata as devoluções da Engine
                if(estado == ESTADO_PROXIMA_FASE) { faseAtual++; tempoInicio = time(0); continue; }
                if(estado == ESTADO_DESISTIU) break; 
                
                int escolha = telaGameOver(estado);
                if(escolha == 1) { resetarEstadoPartida(); tempoInicio = time(0); continue; }
                if(escolha == 2) { resetarPartidaCompleta(); dificuldade = telaSelecionarDificuldade(); tempoInicio = time(0); continue; }
                break;
            }
        }
        else if(op == 2) { cabecalhoTela("COMO JOGAR", 33); cout << "    W/A/S/D ... Mover\n    B ......... Bomba\n    F ......... Desistir\n\n"; aguardarTecla(); }
        else if(op == 3) { cabecalhoTela("DIFICULDADES", 33); cout << "    FACIL: 3 inimigos.\n    MEDIO: 5 inimigos.\n    DIFICIL: 7 inimigos + Boss.\n"; aguardarTecla(); }
        else if(op == 4) { cabecalhoTela("PONTUACAO", 33); cout << "    +100 Inimigo\n    +500 Boss\n    +25 Caixa\n"; aguardarTecla(); }
        else if(op == 5) {
            cabecalhoTela("RANK - TOP 10", 33); RankEntry arr[10]; int qtd = lerRank(arr, 10);
            if(qtd == 0) cout << "  Nenhuma partida registrada ainda.\n";
            else for(int i=0; i<qtd; i++) { char linha[150]; sprintf(linha, "  %3d  %7d  %4d   %-20s %s", i+1, arr[i].pontuacao, arr[i].fase, arr[i].jogador, arr[i].data); cout << linha << "\n"; }
            aguardarTecla();
        }
        else if(op == 6) { // CARREGAR SAVE
            if(telaCarregarSave()) {
                modoAutoPlay = false; 
                while(true) {
                    int estado = executarFase();
                    
                    if(estado == ESTADO_PROXIMA_FASE) { faseAtual++; tempoInicio = time(0); continue; }
                    if(estado == ESTADO_DESISTIU) break; 
                    
                    int escolha = telaGameOver(estado);
                    if(escolha == 1) { resetarEstadoPartida(); tempoInicio = time(0); continue; }
                    if(escolha == 2) { resetarPartidaCompleta(); dificuldade = telaSelecionarDificuldade(); tempoInicio = time(0); continue; }
                    break;
                }
            }
        }
        else if(op == 8) { // SAIR DO JOGO
            system("cls"); 
            setCor(196); imprimirCentralizado("Ate a proxima!", 70); setCor(7); 
            return 0; 
        }
    }
    return 0;
}
