bool posicaoLivre(int x, int y){

    if(x == inimigoX && y == inimigoY) return false;
    if(x == inimigo2X && y == inimigo2Y) return false;
    if(x == inimigo3X && y == inimigo3Y) return false;
    return true;

}


void moverInimigo(int &x, int &y, int m[][25]){ // FUNÇÃO PARA MOVIMENTAÇÃO DO INIMIGO

    int dir = rand() % 4; // SORTEIA UMA DIREÇÃO ENTRE 0 e 3

    // VERIFIÇÃO PARA MOVIMENTAÇÃO EM CAMINHO LIVRE "0", EXPLOSÃO "6" E INIMIGOS "X"

    if(dir == 0 && (m[x-1][y] == 0 || m[x-1][y] == 6) && posicaoLivre(x-1, y)) x--;// CIMA
    if(dir == 1 && (m[x+1][y] == 0 || m[x+1][y] == 6) && posicaoLivre(x+1, y)) x++;// BAIXO
    if(dir == 2 && (m[x][y-1] == 0 || m[x][y-1] == 6) && posicaoLivre(x, y-1)) y--;// ESQUERDA
    if(dir == 3 && (m[x][y+1] == 0 || m[x][y+1] == 6) && posicaoLivre(x, y+1)) y++;// DIREITA
}


void bomba(int x, int y, int m [][25]){ //FUNÇÃO PARA CHAMAR A BOMBA

