// Calcula o bônus no final da fase (quando entra no portal)
// Penaliza por movimentos desnecessários e uso de bombas
int calcularBonusFinal() {
    long tempoGasto = (long)(time(0) - tempoInicio); if(tempoGasto < 1) tempoGasto = 1;
    return (1000 / (int)tempoGasto) - (movimentos / 5) - (bombasUsadas * 2);
}

// Verifica se a posição X, Y não contém nenhum inimigo ou boss
bool posicaoLivreCompleta(int x, int y) {
    for(int i = 0; i < numInimigosAtivos; i++)
        if(inimigos[i].vivo && inimigos[i].x == x && inimigos[i].y == y) return false;
    if(bossAtivo && boss.vivo && boss.x == x && boss.y == y) return false;
    return true;
}

// Inteligência Artificial (IA) dos inimigos comuns
// Eles têm uma chance % de ignorar o caminho aleatório e "caçar" o jogador (px, py)
void moverInimigoIA(int &x, int &y, int m[][25], int px, int py, int chancePerseguir = 0) {
    // Tenta perseguir se cair na probabilidade
    if(rand() % 100 < chancePerseguir) {
        // Verifica pra qual lado o player está (dá -1, 0 ou 1)
        int dx = (px > x) - (px < x); 
        int dy = (py > y) - (py < y);
        bool tentaXprimeiro = rand() % 2; // Sorteia se ele tenta andar na horizontal ou vertical primeiro
        
        for(int tent=0; tent<2; tent++) {
            bool agoraX = (tent==0) ? tentaXprimeiro : !tentaXprimeiro;
            if(agoraX && dx != 0) {
                int nx = x + dx; 
                // Se o lado estiver livre, caminha e interrompe a função
                if((m[nx][y]==0 || m[nx][y]==6) && posicaoLivreCompleta(nx, y)) { x = nx; return; }
            } else if(!agoraX && dy != 0) {
                int ny = y + dy; 
                if((m[x][ny]==0 || m[x][ny]==6) && posicaoLivreCompleta(x, ny)) { y = ny; return; }
            }
        }
    }
    
    // Se não perseguiu (ou não conseguiu caminho), anda aleatoriamente
    int dir = rand() % 4;
    if(dir == 0 && (m[x-1][y] == 0 || m[x-1][y] == 6) && posicaoLivreCompleta(x-1, y)) x--;
    if(dir == 1 && (m[x+1][y] == 0 || m[x+1][y] == 6) && posicaoLivreCompleta(x+1, y)) x++;
    if(dir == 2 && (m[x][y-1] == 0 || m[x][y-1] == 6) && posicaoLivreCompleta(x, y-1)) y--;
    if(dir == 3 && (m[x][y+1] == 0 || m[x][y+1] == 6) && posicaoLivreCompleta(x, y+1)) y++;
}

// IA do Boss (Mais complexa, pois usa Heurística e evita perigos ativamente)
void moverBoss(int &bx, int &by, int m[][25], int px, int py) {
    int dirs[5][2] = {{-1,0},{1,0},{0,-1},{0,1},{0,0}}; // Pode ficar parado também
    int melhorScore = -100000; 
    int melhorDX = 0, melhorDY = 0;
    
    for(int i=0; i<5; i++) {
        int nx = bx + dirs[i][0], ny = by + dirs[i][1];
        
        if(nx<1 || nx>13 || ny<1 || ny>23) continue; // Fora do mapa
        if(i != 4 && m[nx][ny] != 0 && m[nx][ny] != 6) continue; // Bateu em parede
        if(i != 4 && !posicaoLivreCompleta(nx, ny)) continue; // Bateu em inimigo

        // O Score (pontuação da direção) começa pela distância de manhattan (Tentar chegar no player)
        int score = -(abs(nx - px) + abs(ny - py)) * 10;
        
        // Punição Severa (Evita morte) se o bloco analisado tiver fogo ou bomba perto
        if(m[nx][ny] == 6) score -= 5000;
        if(nx>0 && m[nx-1][ny]==5) score -= 2000;
        if(nx<14 && m[nx+1][ny]==5) score -= 2000;
        if(ny>0 && m[nx][ny-1]==5) score -= 2000;
        if(ny<24 && m[nx][ny+1]==5) score -= 2000;
        
        if(i == 4) score -= 5; // Punição leve para não ficar parado o tempo todo

        // Salva a melhor rota identificada
        if(score > melhorScore) { 
            melhorScore = score; melhorDX = dirs[i][0]; melhorDY = dirs[i][1]; 
        }
    }
    // Aplica a melhor movimentação encontrada
    bx += melhorDX; by += melhorDY;
}

// Modo AutoPlay (IA para o Personagem Principal)
void jogarBot(int &x, int &y, int m[][25], bool &tentarBomba) {
    tentarBomba = false;
    int dirs[5][2] = {{0,0}, {-1,0}, {1,0}, {0,-1}, {0,1}};
    int melhorScore = -999999; int melhorDir = 0;

    for(int i=0; i<5; i++) {
        int nx = x + dirs[i][0], ny = y + dirs[i][1];
        if(nx<1 || nx>13 || ny<1 || ny>23) continue;
        if(i != 0 && m[nx][ny] != 0 && m[nx][ny] != 6 && m[nx][ny] != 7) continue;

        int score = 0;
        
        // Regra de Sobrevivência (Morte certa = Punição máxima)
        if(m[nx][ny] == 6 || m[nx][ny] == 5) score -= 10000;
        if(nx>0 && m[nx-1][ny]==5) score -= 5000;
        if(nx<14 && m[nx+1][ny]==5) score -= 5000;
        if(ny>0 && m[nx][ny-1]==5) score -= 5000;
        if(ny<24 && m[nx][ny+1]==5) score -= 5000;

        // Distância até o inimigo mais próximo
        int distInimigo = 999;
        for(int k=0; k<numInimigosAtivos; k++) {
            if(inimigos[k].vivo) {
                int dist = abs(nx - inimigos[k].x) + abs(ny - inimigos[k].y);
                if(dist < distInimigo) distInimigo = dist;
            }
        }
        if(bossAtivo && boss.vivo) {
            int dist = abs(nx - boss.x) + abs(ny - boss.y);
            if(dist < distInimigo) distInimigo = dist;
        }

        // Foge ativamente se os inimigos chegam perto demais
        if(distInimigo <= 1) score -= 8000; 
        else if(distInimigo == 2) score -= 2000;

        // Se o portal já abriu, ignora caixas e foca em entrar nele
        if(portalAtivo) {
            score -= (abs(nx - portalX) + abs(ny - portalY)) * 10; 
        } else {
            // Conta as caixas quebrando e premia essa direção
            int caixas = 0;
            if(nx>0 && m[nx-1][ny]==4) caixas++; if(nx<14 && m[nx+1][ny]==4) caixas++;
            if(ny>0 && m[nx][ny-1]==4) caixas++; if(ny<24 && m[nx][ny+1]==4) caixas++;
            score += caixas * 50; 
            
            // Vai caçar inimigo (mas sempre respeitando a distância perigosa lida acima)
            score -= distInimigo * 5; 
        }
        
        score += rand() % 10; // Quebra de padrão pra não travar num loop infinito (ficar indo e voltando)
        if(score > melhorScore) { melhorScore = score; melhorDir = i; }
    }
    
    // Efetua o movimento
    x += dirs[melhorDir][0]; y += dirs[melhorDir][1];

    // Lógica para soltar bomba (apenas se for vantajoso e portal não ativado)
    if(!portalAtivo) {
        int caixas = 0;
        if(x>0 && m[x-1][y]==4) caixas++; if(x<14 && m[x+1][y]==4) caixas++;
        if(y>0 && m[x][y-1]==4) caixas++; if(y<24 && m[x][y+1]==4) caixas++;
        
        bool iniVizinho = false;
        for(int k=0; k<numInimigosAtivos; k++)
            if(inimigos[k].vivo && (abs(x - inimigos[k].x) + abs(y - inimigos[k].y) <= 2)) iniVizinho = true;
            
        // Se parou do lado de caixa ou inimigo, 20% de chance de apertar o 'B' e correr
        if((caixas > 0 || iniVizinho) && (rand() % 100 < 20)) tentarBomba = true;
    }
}

// Funções de controle da explosão (Criação e Limpeza na Matriz)
void bomba(int x, int y, int m[][25]) {
    if(!bombaAtiva && !bombaExplodiu) {
        bombaX = x; bombaY = y; bombaAtiva = true; bombaTimer = 7; m[bombaX][bombaY] = 5;
    }
}

void explosao(int x, int y, int m[][25]) {
    m[x][y] = 6;
    if(m[x-1][y]==0 || m[x-1][y]==4) m[x-1][y]= 6; if(m[x+1][y]==0 || m[x+1][y]==4) m[x+1][y]= 6;
    if(m[x][y-1]==0 || m[x][y-1]==4) m[x][y-1]= 6; if(m[x][y+1]==0 || m[x][y+1]==4) m[x][y+1]= 6;
}

void fimExplosao(int x, int y, int m[][25]) {
    if(m[x][y] == 6) m[x][y] = 0;
    if(m[x-1][y] == 6) m[x-1][y] = 0; if(m[x+1][y] == 6) m[x+1][y] = 0;
    if(m[x][y-1] == 6) m[x][y-1] = 0; if(m[x][y+1] == 6) m[x][y+1] = 0;
}


